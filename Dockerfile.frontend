# Frontend – build from repo root (used by docker-compose)
# Same as frontend/Dockerfile; kept at root so compose always finds it.
FROM node:20-alpine

WORKDIR /app

COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install

COPY frontend/ .

EXPOSE 3001

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
