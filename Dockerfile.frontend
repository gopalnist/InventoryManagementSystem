# Frontend – build from repo root (used by docker-compose)
FROM node:20-alpine

WORKDIR /app

COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci && echo "npm ci OK — $(ls node_modules/.bin/vite && echo 'vite found')"

COPY frontend/ .

EXPOSE 3001

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
